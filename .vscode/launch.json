{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Simulator",
      "type": "debugpy",
      "request": "launch",
      "python": "/home/pisorul/.cache/pypoetry/virtualenvs/sorul-tradingbot-hpqtalII-py3.11/bin/python",
      "program": "${workspaceFolder}/sorul_tradingbot/strategy/simulator/simulator.py",
      "args": [
        "--data-file",
        "${input:SimulatorDataFile}",
        "--strategy-module",
        "${input:SimulatorStrategyModule}",
        "--description",
        "${input:SimulatorDescription}",
        "--start-date",
        "${input:SimulatorStartDate}",
        "--finish-date",
        "${input:SimulatorFinishDate}"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Forex",
      "type": "debugpy",
      "request": "launch",
      "python": "/home/pisorul/.cache/pypoetry/virtualenvs/sorul-tradingbot-hpqtalII-py3.11/bin/python",
      "program": "${workspaceFolder}/sorul_tradingbot/main_forex.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    }
  ],
  "inputs": [
    {
      "id": "SimulatorDataFile",
      "type": "promptString",
      "description": "Ruta al CSV a usar en el simulador",
      "default": "sorul_tradingbot/strategy/simulator/data/sp500_test.csv"
    },
    {
      "id": "SimulatorStrategyModule",
      "type": "promptString",
      "description": "Ruta del módulo de estrategia (p.ej. sorul_tradingbot.strategy.private.volume_12)",
      "default": "sorul_tradingbot.strategy.private.volume_12"
    },
    {
      "id": "SimulatorDescription",
      "type": "promptString",
      "description": "Notas libres para guardar en simulation_summary.txt",
      "default": ""
    },
    {
      "id": "SimulatorStartDate",
      "type": "promptString",
      "description": "Optional date (YYYY-MM-DD) to run the simulation up to (inclusive). Leave empty to use all data.",
      "default": "2024-12-01"
    },
    {
      "id": "SimulatorFinishDate",
      "type": "promptString",
      "description": "Optional date (YYYY-MM-DD) to run the simulation up to (inclusive). Leave empty to use all data.",
      "default": "2050-12-01"
    }
  ]
}
